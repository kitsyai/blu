{
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "rimraf dist && tsc && npm run copy:assets && npm run copy:config && npm run copy:bundle",
    "copy:config": "node -e \"fs.cpSync('config', 'dist', { recursive: true })\"",
    "copy:assets": "node -e \"fs.cpSync('public', 'dist', { recursive: true })\"",
    "copy:bundle": "node -e \"fs.cpSync('node_modules/@kitsy/blu/dist/umd/blu.standalone.min.js', 'dist/blu.standalone.min.js', { recursive: true })\"",
    "start": "node dist/server.js",
    "install:local": "npm install ../../kitsy-blu-core-0.0.12.tgz ../../kitsy-blu-bus-0.0.12.tgz ../../kitsy-blu-context-0.0.12.tgz ../../kitsy-blu-ui-0.0.12.tgz ../../kitsy-blu-icons-0.0.12.tgz ../../kitsy-blu-grid-0.0.12.tgz ../../kitsy-blu-route-0.0.12.tgz ../../kitsy-blu-blocks-0.0.12.tgz ../../kitsy-blu-0.0.12.tgz"
  },
  "dependencies": {
    "@kitsy/blu": "file:../../kitsy-blu-0.0.12.tgz",
    "@kitsy/blu-core": "file:../../kitsy-blu-core-0.0.12.tgz",
    "@kitsy/blu-ui": "file:../../kitsy-blu-ui-0.0.12.tgz",
    "@kitsy/blu-context": "file:../../kitsy-blu-context-0.0.12.tgz",
    "@kitsy/blu-icons": "file:../../kitsy-blu-icons-0.0.12.tgz",
    "@kitsy/blu-bus": "file:../../kitsy-blu-bus-0.0.12.tgz",
    "@kitsy/blu-grid": "file:../../kitsy-blu-grid-0.0.12.tgz",
    "@kitsy/blu-route": "file:../../kitsy-blu-route-0.0.12.tgz",
    "@kitsy/blu-blocks": "file:../../kitsy-blu-blocks-0.0.12.tgz",
    "express": "^4.19.2",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  }
