{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@kitsy/blu-core": ["packages/blu-core/src/index.ts"],
      "@kitsy/blu-schema": ["packages/blu-schema/src/index.ts"],
      "@kitsy/blu-validate": ["packages/blu-validate/src/index.ts"],
      "@kitsy/blu-bus": ["packages/blu-bus/src/index.ts"],
      "@kitsy/blu-slate": ["packages/blu-slate/src/index.ts"],
      "@kitsy/blu-wire": ["packages/blu-wire/src/index.ts"],
      "@kitsy/blu-context": ["packages/blu-context/src/index.ts"],
      "@kitsy/blu-devtools": ["packages/blu-devtools/src/index.ts"],
      "@kitsy/blu-view": ["packages/blu-view/src/index.ts"],
      "@kitsy/blu-style": ["packages/blu-style/src/index.ts"],
      "@kitsy/blu-grid": ["packages/blu-grid/src/index.ts"],
      "@kitsy/blu-ui": ["packages/blu-ui/src/index.ts"],
      "@kitsy/blu-shell": ["packages/blu-shell/src/index.ts"],
      "@kitsy/blu-route": ["packages/blu-route/src/index.ts"],
      "@kitsy/blu-cli": ["packages/blu-cli/src/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowSyntheticDefaultImports": true,
    "importHelpers": false
  }
}
