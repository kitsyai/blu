{
  "name": "kitsy-blu-workspace",
  "private": true,
  "type": "module",
  "version": "1.0.0-dev",
  "description": "Blu — event-first, schema-driven UI framework. Workspace root.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Prashant Sinha",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsy-ai/kitsy.git"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "prettier --check \"packages/blu-*/src/**/*.{ts,tsx,js,jsx,json}\"",
    "format": "prettier --write \"packages/blu-*/src/**/*.{ts,tsx,js,jsx,json}\"",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "fresh": "pnpm clean && pnpm install"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20"
  }
}
