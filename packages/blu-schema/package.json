{
  "name": "@kitsy/blu-schema",
  "version": "1.0.0-dev.0",
  "description": "Blu schema types: ApplicationConfiguration, ViewNode, DataSource, FormDefinition, Action, Condition, ComponentMeta. Types-only.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsy-ai/kitsy.git",
    "directory": "packages/blu-schema"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Prashant Sinha",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@kitsy/blu-core": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20"
  }
}
